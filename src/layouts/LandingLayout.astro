---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: object;
}
const { title, description, canonical, schema } = Astro.props;
---
<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <Header />
  <main class="lp"><slot /></main>
  <Footer />
</Layout>

<style is:global>
  .lp .container { max-width: 980px; }
  .lp-wide .container { max-width: 1120px; }

  /* Breadcrumb */
  .crumbs { font-size: 0.82rem; color: #8a7a66; padding: 1.25rem 0 0; }
  .crumbs a { color: #8a7a66; text-decoration: none; }
  .crumbs a:hover { color: var(--caramel); }

  /* Hero */
  .lp-hero { background: var(--brown); color: #fff; padding: 3.5rem 0 4rem; }
  .lp-hero .tag { display: inline-block; background: var(--caramel); color: #fff; padding: 0.35rem 0.9rem; border-radius: 99px; font-size: 0.82rem; font-weight: 600; margin-bottom: 1rem; }
  .lp-hero h1 { color: #fff; font-size: clamp(1.9rem, 4vw, 2.8rem); margin-bottom: 1rem; max-width: 800px; }
  .lp-hero .lead { color: #d3c4ad; font-size: 1.12rem; max-width: 680px; margin-bottom: 1.75rem; }
  .lp-hero .actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .lp-hero .note { font-size: 0.85rem; color: #b3a48d; }

  /* Sections */
  .lp-section { padding: 3.5rem 0; }
  .lp-section.alt { background: var(--sand); }
  .lp-section h2 { font-size: clamp(1.4rem, 3vw, 2rem); margin-bottom: 0.75rem; }
  .lp-section .lead { color: #555; max-width: 720px; margin-bottom: 2rem; font-size: 1.05rem; }
  .lp-section p { color: #444; margin-bottom: 1rem; line-height: 1.7; }
  .lp-section h3 { font-size: 1.15rem; margin: 1.75rem 0 0.5rem; }

  /* Cards grid */
  .lp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
  .lp-card { background: #fff; border: 1px solid var(--sand); border-radius: 14px; padding: 1.5rem; }
  .lp-section.alt .lp-card { background: #fff; }
  .lp-card .ico { font-size: 1.6rem; display: block; margin-bottom: 0.6rem; }
  .lp-card h3 { margin: 0 0 0.4rem; font-size: 1.05rem; }
  .lp-card p { font-size: 0.93rem; color: #555; margin: 0; }

  /* Comparison table */
  .lp-table-wrap { overflow-x: auto; margin-top: 1.5rem; }
  .lp-table { width: 100%; border-collapse: collapse; min-width: 560px; background: #fff; border-radius: 14px; overflow: hidden; border: 1px solid var(--sand); }
  .lp-table th, .lp-table td { padding: 0.85rem 1rem; text-align: left; font-size: 0.92rem; border-bottom: 1px solid var(--sand); }
  .lp-table thead th { background: var(--brown); color: #fff; font-family: var(--font-title); }
  .lp-table th[scope="row"] { font-weight: 600; color: var(--brown); }
  .lp-table .yes { color: var(--green); font-weight: 700; }
  .lp-table .no { color: #c0392b; }
  .lp-table .hl { background: #fbf1e4; }

  /* FAQ */
  .lp-faq { max-width: 760px; }
  .lp-faq details { border-bottom: 1px solid var(--sand); }
  .lp-faq summary { cursor: pointer; padding: 1.1rem 0; font-weight: 600; list-style: none; display: flex; justify-content: space-between; gap: 1rem; }
  .lp-faq summary::after { content: '+'; color: var(--caramel); font-size: 1.2rem; }
  .lp-faq details[open] summary::after { content: '−'; }
  .lp-faq details p { padding: 0 0 1.1rem; color: #555; font-size: 0.96rem; }

  /* CTA band */
  .lp-cta { background: var(--caramel); color: #fff; padding: 2.5rem 0; }
  .lp-cta .inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .lp-cta h2 { color: #fff; font-size: 1.5rem; margin: 0; }
  .lp-cta p { color: rgba(255,255,255,0.9); margin: 0.3rem 0 0; }
  .lp-cta .btn { background: #fff; color: var(--caramel); white-space: nowrap; }

  /* Internal links list */
  .lp-related { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1rem; }
  .lp-related a { background: #fff; border: 1px solid var(--sand); border-radius: 99px; padding: 0.5rem 1rem; font-size: 0.9rem; text-decoration: none; color: var(--brown); }
  .lp-related a:hover { border-color: var(--caramel); color: var(--caramel); }

  .lp ul.checks { list-style: none; margin: 1rem 0; }
  .lp ul.checks li { padding: 0.35rem 0 0.35rem 1.6rem; position: relative; color: #444; }
  .lp ul.checks li::before { content: '✓'; position: absolute; left: 0; color: var(--green); font-weight: 700; }

  @media (max-width: 768px) {
    .lp-cta .inner { flex-direction: column; text-align: center; }
  }
</style>
