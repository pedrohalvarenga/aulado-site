---
import LandingLayout from '../layouts/LandingLayout.astro';

const canonical = 'https://aupipet.com.br/hotel-pet';
const faqs = [
  { q: 'A Aupipet controla a ocupação do hotel pet por período?', a: 'Sim. Você cadastra as reservas com entrada e saída, vê a ocupação por dia e o sistema evita overbooking. A diária é calculada automaticamente.' },
  { q: 'Dá para organizar a escala dos plantonistas?', a: 'Sim. O módulo de hotel tem escala de plantonistas e relatório diário, para a operação rodar mesmo nos fins de semana e feriados.' },
  { q: 'O tutor recebe atualização da hospedagem?', a: 'Sim. O tutor acompanha a reserva e o histórico do pet por um app web responsivo com a identidade do seu negócio.' },
  { q: 'Consigo trazer meus dados de outro sistema?', a: 'Sim, automaticamente: envie planilha (Excel/CSV), PDF ou foto das fichas e a Aupipet lê, organiza e cadastra tutores e pets. Você só confere e confirma.' },
];
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://aupipet.com.br' },
      { '@type': 'ListItem', position: 2, name: 'Hotel pet', item: canonical },
    ] },
  ],
};
---
<LandingLayout
  title="Sistema para hotel pet — reservas, ocupação e cobrança | Aupipet"
  description="Aupipet é o sistema de gestão para hotel pet: reservas, mapa de ocupação, escala de plantonistas, relatório diário e cobrança automática — com a sua marca. Teste 14 dias grátis."
  canonical={canonical}
  schema={schema}
>
  <nav class="container crumbs"><a href="/">Início</a> › Hotel pet</nav>

  <section class="lp-hero">
    <div class="container">
      <span class="tag">🏨 Para hotéis pet</span>
      <h1>Sistema para hotel pet</h1>
      <p class="lead">Reservas, ocupação por período, escala de plantonistas, relatório diário e cobrança — tudo organizado e com a identidade visual do seu hotel. Sem planilha, sem overbooking.</p>
      <div class="actions">
        <a href="https://app.aupipet.com.br/comecar" class="btn btn-primary">Começar teste grátis de 14 dias</a>
        <span class="note">Sem cartão · Sem compromisso · Acesso imediato</span>
      </div>
    </div>
  </section>

  <section class="lp-section">
    <div class="container">
      <h2>A operação do hotel sob controle</h2>
      <p class="lead">Da reserva ao check-out, com a equipe toda na mesma página.</p>
      <div class="lp-grid">
        <div class="lp-card"><span class="ico">🗓️</span><h3>Reservas e ocupação</h3><p>Cadastre entrada e saída, veja a ocupação por dia e evite overbooking. A diária é calculada sozinha.</p></div>
        <div class="lp-card"><span class="ico">👥</span><h3>Escala de plantonistas</h3><p>Organize quem trabalha em cada dia e mantenha a operação rodando em fins de semana e feriados.</p></div>
        <div class="lp-card"><span class="ico">📋</span><h3>Relatório diário</h3><p>O resumo do dia — quem entrou, quem saiu e quem está hospedado — pronto para a equipe e para o tutor.</p></div>
        <div class="lp-card"><span class="ico">🐶</span><h3>Ficha digital completa</h3><p>Saúde, vacinação, alergias, rotina e autorizações em destaque no check-in, para toda a equipe.</p></div>
        <div class="lp-card"><span class="ico">💳</span><h3>Cobrança automática</h3><p>Diárias, pacotes e adicionais com cobrança e régua de inadimplência. Menos cobrança manual.</p></div>
        <div class="lp-card"><span class="ico">📊</span><h3>Relatórios e caixa</h3><p>Ocupação, faturamento por serviço, ticket médio e previsão de caixa — sem montar planilha.</p></div>
      </div>
    </div>
  </section>

  <section class="lp-section alt">
    <div class="container">
      <h2>Migre o seu hotel sem retrabalho</h2>
      <p class="lead">Comece com o que você já tem e deixe a Aupipet organizar.</p>
      <ul class="checks">
        <li>Importação automática: planilha, PDF ou foto das fichas viram cadastros de tutores e pets.</li>
        <li>White label completo: logo, cores e nome do hotel no painel, nas páginas do tutor e nos e-mails.</li>
        <li>App do tutor para acompanhar a hospedagem e o histórico do pet.</li>
        <li>100% self-service: configure em minutos, sem reunião e sem esperar atendimento.</li>
      </ul>
      <div class="lp-related">
        <a href="/blog/relatorios-hotel-pet-creche">Relatórios de hotel e creche</a>
        <a href="/blog/ficha-anamnese-creche-hotel-pet-modelo">Modelo de ficha de anamnese</a>
        <a href="/blog/como-precificar-servicos-creche-pet">Como precificar</a>
      </div>
    </div>
  </section>

  <section class="lp-section">
    <div class="container lp-faq">
      <h2>Perguntas frequentes</h2>
      {faqs.map(f => (
        <details><summary>{f.q}</summary><p>{f.a}</p></details>
      ))}
    </div>
  </section>

  <section class="lp-cta">
    <div class="container inner">
      <div>
        <h2>Coloque o seu hotel pet no piloto automático</h2>
        <p>14 dias grátis, sem cartão. Configuração em menos de 15 minutos.</p>
      </div>
      <a href="https://app.aupipet.com.br/comecar" class="btn">Começar teste grátis →</a>
    </div>
  </section>
</LandingLayout>
