---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Blog Aupi — Gestão de creche pet, hotel e banho e tosa"
  description="Artigos práticos sobre gestão, finanças, operação e marketing para donos de creche de cachorro, hotel pet e banho e tosa."
  canonical="https://aupipet.com.br/blog"
>
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">
        <svg width="32" height="32" viewBox="0 0 36 36" fill="none">
          <rect width="36" height="36" rx="8" fill="#D98232"/>
          <g fill="#fff">
            <ellipse cx="9.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(-22 9.5 17.5)"/>
            <ellipse cx="14.8" cy="11.6" rx="2.7" ry="3.9" transform="rotate(-8 14.8 11.6)"/>
            <ellipse cx="21.2" cy="11.6" rx="2.7" ry="3.9" transform="rotate(8 21.2 11.6)"/>
            <ellipse cx="26.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(22 26.5 17.5)"/>
            <path d="M18 18.6C23.1 18.6 27 21.9 27 25.9C27 29.3 24.2 30.9 21.4 32.3C20 33 19.1 33.5 18 33.5C16.9 33.5 16 33 14.6 32.3C11.8 30.9 9 29.3 9 25.9C9 21.9 12.9 18.6 18 18.6Z"/>
          </g>
        </svg>
        <span>Aupi</span>
      </a>
      <nav>
        <a href="/#funcionalidades">Funcionalidades</a>
        <a href="/#planos">Planos</a>
        <a href="/blog">Blog</a>
        <a href="/#contato" class="btn btn-primary" style="padding:0.5rem 1.2rem;font-size:0.9rem;">Teste grátis</a>
      </nav>
    </div>
  </header>

  <main>
    <div class="blog-hero">
      <div class="container">
        <h1>Blog Aupi</h1>
        <p>Gestão prática para creche de cachorro, hotel pet e banho e tosa. Sem enrolação.</p>
      </div>
    </div>

    <section class="blog-list">
      <div class="container">
        <div class="posts-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="post-card">
              <div class="post-card-tags">
                {post.data.tags?.slice(0, 2).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="post-card-meta">
                <time>{post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}</time>
                {post.data.readingTime && <span>{post.data.readingTime} min</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="blog-cta">
      <div class="container">
        <div class="cta-inline">
          <p>🐾 Gostou do conteúdo? Teste a Aupi grátis por 14 dias.</p>
          <a href="/#contato" class="btn btn-primary">Começar agora</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>© {new Date().getFullYear()} Aupi · <a href="/politica-de-privacidade">Privacidade</a> · <a href="/termos-de-uso">Termos</a> · <a href="/#faq">Central de ajuda</a></p>
    </div>
  </footer>
</Layout>

<style>
  .site-header { background: var(--brown); padding: 1rem 0; }
  .site-header .container { display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: #fff; font-family: var(--font-title); font-weight: 700; font-size: 1.1rem; }
  nav { display: flex; align-items: center; gap: 1.5rem; }
  nav a { color: #fff; text-decoration: none; font-size: 0.9rem; }

  .blog-hero { background: var(--brown); color: #fff; padding: 3.5rem 0 3rem; }
  .blog-hero h1 { font-size: clamp(2rem, 4vw, 2.8rem); color: #fff; margin-bottom: 0.75rem; }
  .blog-hero p { color: #bbb; font-size: 1.05rem; }

  .blog-list { padding: 4rem 0; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .post-card { display: block; background: #fff; border-radius: 14px; padding: 1.75rem; text-decoration: none; border: 1.5px solid var(--sand); transition: transform 0.15s, border-color 0.15s; }
  .post-card:hover { transform: translateY(-4px); border-color: var(--caramel); }
  .post-card-tags { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; flex-wrap: wrap; }
  .tag { background: var(--sand); color: #666; font-size: 0.75rem; padding: 0.2rem 0.6rem; border-radius: 99px; }
  .post-card h2 { font-size: 1.05rem; color: var(--brown); margin-bottom: 0.5rem; line-height: 1.35; }
  .post-card p { font-size: 0.88rem; color: #666; margin-bottom: 1rem; }
  .post-card-meta { display: flex; gap: 0.75rem; font-size: 0.8rem; color: #999; }

  .blog-cta { padding: 0 0 4rem; }
  .cta-inline { background: var(--brown); border-radius: 14px; padding: 1.75rem 2rem; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .cta-inline p { color: #fff; font-size: 1rem; margin: 0; }

  .site-footer { background: #1a140c; color: #666; text-align: center; padding: 1.5rem 0; font-size: 0.85rem; }
  .site-footer a { color: var(--caramel); }

  @media (max-width: 768px) { nav a:not(.btn) { display: none; } }
</style>
