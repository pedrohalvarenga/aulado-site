---
import Layout from '../layouts/Layout.astro';

const siteSchema = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Aulado",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": [
      { "@type": "Offer", "name": "Essencial", "price": "197", "priceCurrency": "BRL", "billingIncrement": "P1M" },
      { "@type": "Offer", "name": "Profissional", "price": "397", "priceCurrency": "BRL", "billingIncrement": "P1M" },
      { "@type": "Offer", "name": "Escala", "price": "697", "priceCurrency": "BRL", "billingIncrement": "P1M" }
    ],
    "url": "https://aulado.com.br",
    "description": "Sistema de gestão white label para creches de cachorro, hotéis pet e banho e tosa."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Preciso de cartão de crédito para o teste grátis?",
        "acceptedAnswer": { "@type": "Answer", "text": "Não. O trial de 14 dias é totalmente gratuito, sem cartão e sem compromisso." }
      },
      {
        "@type": "Question",
        "name": "O que é o plano white label?",
        "acceptedAnswer": { "@type": "Answer", "text": "No plano Profissional e Escala, o sistema aparece com o nome e a identidade visual do seu negócio — para os seus tutores, é o seu próprio app." }
      },
      {
        "@type": "Question",
        "name": "Posso migrar meus dados do sistema atual?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sim. Nossa equipe faz a migração dos dados da maioria dos sistemas do mercado sem custo adicional." }
      },
      {
        "@type": "Question",
        "name": "Funciona para banho e tosa também?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sim — agendamento, lembretes, pacotes e cobranças funcionam para creche, hotel pet e banho e tosa." }
      }
    ]
  }
];

const FORMSPREE_ID = import.meta.env.FORMSPREE_ID || 'xyzabcde';
---

<Layout
  title="Aulado — Sistema de gestão para creche, hotel pet e banho e tosa"
  description="Aulado é o sistema que organiza agenda, tutores, cobranças e relatórios do seu pet negócio — com a sua marca. Trial de 14 dias sem cartão."
  schema={siteSchema}
>

<!-- HEADER -->
<header class="site-header">
  <div class="container">
    <a href="/" class="logo" aria-label="Aulado — início">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
        <rect width="36" height="36" rx="8" fill="#D98232"/>
        <path d="M12 22c0-1.5.8-2.8 2-3.5-.3-.5-.5-1-.5-1.5 0-1.7 1.3-3 3-3s3 1.3 3 3c0 .5-.2 1-.5 1.5 1.2.7 2 2 2 3.5H12z" fill="white"/>
        <circle cx="13" cy="13" r="1.5" fill="white"/>
        <circle cx="23" cy="13" r="1.5" fill="white"/>
        <circle cx="10" cy="17" r="1.5" fill="white"/>
        <circle cx="26" cy="17" r="1.5" fill="white"/>
      </svg>
      <span>Aulado</span>
    </a>
    <nav>
      <a href="#funcionalidades">Funcionalidades</a>
      <a href="#planos">Planos</a>
      <a href="/blog">Blog</a>
      <a href="#contato" class="btn btn-primary nav-cta">Teste grátis</a>
    </nav>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">🐾 Cupom FUNDADOR — R$97/mês vitalício · apenas 10 vagas</div>
      <h1>Seu pet negócio organizado.<br/>Sua marca em cada detalhe.</h1>
      <p>Aulado é o sistema que cuida da agenda, dos tutores, das cobranças e dos relatórios da sua creche, hotel pet ou banho e tosa — com a cara do seu negócio, sem complicação.</p>
      <div class="hero-actions">
        <a href="#contato" class="btn btn-primary">Começar teste grátis de 14 dias</a>
        <span class="hero-note">Sem cartão · Sem compromisso · Acesso imediato</span>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card">
        <div class="hcard-header">
          <span class="hcard-dot green"></span>
          <span class="hcard-title">Hoje — ocupação</span>
        </div>
        <div class="hcard-stat">28<span>/30</span></div>
        <div class="hcard-label">cães presentes</div>
        <div class="hcard-checks">
          <div class="hcheck done">✓ Thor — check-in 08:12</div>
          <div class="hcheck done">✓ Mel — check-in 08:45</div>
          <div class="hcheck pending">⏳ Bob — previsto 09:30</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROBLEMA -->
<section class="pain">
  <div class="container">
    <h2>Você ainda gerencia no caderno, no WhatsApp e na memória?</h2>
    <div class="pain-grid">
      <div class="pain-item">
        <span class="pain-icon">📋</span>
        <p>Ficha de cada cão espalhada em papel, planilha e cabeça de funcionário</p>
      </div>
      <div class="pain-item">
        <span class="pain-icon">💸</span>
        <p>Cobrança manual que constrange — e inadimplência que sangra o caixa</p>
      </div>
      <div class="pain-item">
        <span class="pain-icon">📅</span>
        <p>Agendamento por WhatsApp que some, esquece e gera confusão</p>
      </div>
      <div class="pain-item">
        <span class="pain-icon">📊</span>
        <p>Sem saber quanto faturou, quantos faltaram ou quem sumiu há semanas</p>
      </div>
    </div>
    <p class="pain-cta">Isso não é falta de esforço — é falta de sistema. A Aulado resolve.</p>
  </div>
</section>

<!-- FUNCIONALIDADES -->
<section class="features" id="funcionalidades">
  <div class="container">
    <h2>Tudo que você precisa em um lugar só</h2>
    <p class="section-subtitle">Desenvolvido com quem já opera pet negócio de verdade — sem funcionalidade de enfeite.</p>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">📅</div>
        <h3>Agenda inteligente</h3>
        <p>Controle de vagas por porte, bloqueio automático na capacidade máxima, lista de espera e confirmação automática na véspera.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🐾</div>
        <h3>Ficha digital completa</h3>
        <p>Saúde, vacinação, comportamento, rotina e autorizações do tutor — acessíveis para toda a equipe, atualizadas em tempo real.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">💳</div>
        <h3>Cobrança recorrente</h3>
        <p>Mensalistas e pacotes com cobrança automática, régua de inadimplência e extrato de saldo para o tutor. Você para de cobrar.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📦</div>
        <h3>Pacotes de diárias</h3>
        <p>Venda, controle de saldo e aviso automático de vencimento. O sistema debita, avisa o tutor e gera a recompra.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <h3>Relatórios em tempo real</h3>
        <p>Ocupação, faturamento por serviço, ticket médio, inativos, faltas e previsão de caixa — prontos, sem montar planilha.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎨</div>
        <h3>White label completo</h3>
        <p>Logo, cor e nome do seu negócio em todo o painel, nas páginas do tutor e nos e-mails. Para seus clientes, é o seu app.</p>
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF -->
<section class="proof">
  <div class="container">
    <div class="proof-stat-grid">
      <div class="proof-stat">
        <span class="stat-number">-68%</span>
        <span class="stat-label">nas faltas com confirmação automática</span>
      </div>
      <div class="proof-stat">
        <span class="stat-number">14 dias</span>
        <span class="stat-label">para organizar o que estava no caderno</span>
      </div>
      <div class="proof-stat">
        <span class="stat-number">100%</span>
        <span class="stat-label">da sua marca nos e-mails e painel do tutor</span>
      </div>
    </div>
  </div>
</section>

<!-- PLANOS -->
<section class="pricing" id="planos">
  <div class="container">
    <h2>Planos que crescem com você</h2>
    <p class="section-subtitle">Todos com trial de 14 dias gratuito. Planos anuais com 2 meses grátis.</p>
    <div class="pricing-grid">
      <div class="plan-card">
        <div class="plan-name">Essencial</div>
        <div class="plan-price">R$&nbsp;197<span>/mês</span></div>
        <div class="plan-annual">ou R$1.970/ano (2 meses grátis)</div>
        <ul class="plan-features">
          <li>✓ 1 unidade · 2 usuários</li>
          <li>✓ Agenda e check-in/out</li>
          <li>✓ Ficha digital dos pets</li>
          <li>✓ Controle de pacotes</li>
          <li>✓ Relatórios básicos</li>
          <li>✓ Cobrança recorrente</li>
        </ul>
        <a href="#contato" class="btn btn-outline" style="width:100%;text-align:center;">Começar grátis</a>
      </div>

      <div class="plan-card plan-featured">
        <div class="plan-badge">Mais popular</div>
        <div class="plan-name">Profissional</div>
        <div class="plan-price">R$&nbsp;397<span>/mês</span></div>
        <div class="plan-annual">ou R$3.970/ano (2 meses grátis)</div>
        <ul class="plan-features">
          <li>✓ Tudo do Essencial</li>
          <li>✓ White label completo</li>
          <li>✓ Usuários ilimitados</li>
          <li>✓ Relatórios avançados</li>
          <li>✓ Subdomínio próprio</li>
          <li>✓ Suporte prioritário</li>
        </ul>
        <a href="#contato" class="btn btn-primary" style="width:100%;text-align:center;">Começar grátis</a>
      </div>

      <div class="plan-card">
        <div class="plan-name">Escala</div>
        <div class="plan-price">R$&nbsp;697<span>/mês</span></div>
        <div class="plan-annual">ou R$6.970/ano (2 meses grátis)</div>
        <ul class="plan-features">
          <li>✓ Tudo do Profissional</li>
          <li>✓ Múltiplas unidades</li>
          <li>✓ Painel consolidado</li>
          <li>✓ API e integrações</li>
          <li>✓ Onboarding dedicado</li>
          <li>✓ SLA garantido</li>
        </ul>
        <a href="#contato" class="btn btn-outline" style="width:100%;text-align:center;">Falar com a equipe</a>
      </div>
    </div>

    <div class="coupon-box">
      <strong>🏷️ Cupom FUNDADOR</strong> — R$97/mês vitalício para os primeiros 10 clientes. Informe no formulário abaixo.
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq">
  <div class="container">
    <h2>Perguntas frequentes</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Preciso de cartão de crédito para o teste?</summary>
        <p>Não. O trial de 14 dias é totalmente gratuito, sem cartão e sem compromisso. Você só paga se decidir continuar.</p>
      </details>
      <details class="faq-item">
        <summary>O que é o plano white label?</summary>
        <p>No plano Profissional e Escala, o sistema aparece com o nome e a identidade visual do seu negócio — logo, cores e domínio. Para os seus tutores, é o seu próprio app.</p>
      </details>
      <details class="faq-item">
        <summary>Posso migrar meus dados do sistema atual?</summary>
        <p>Sim. Nossa equipe faz a migração dos dados da maioria dos sistemas do mercado sem custo adicional durante o onboarding.</p>
      </details>
      <details class="faq-item">
        <summary>Funciona para banho e tosa também?</summary>
        <p>Sim — agendamento, lembretes automáticos, pacotes e cobranças funcionam para creche, hotel pet e banho e tosa.</p>
      </details>
      <details class="faq-item">
        <summary>Tem aplicativo para o tutor?</summary>
        <p>Sim. O tutor acessa a agenda, o histórico do pet e os comprovantes pelo app web responsivo — com a cara do seu negócio.</p>
      </details>
      <details class="faq-item">
        <summary>Como funciona o suporte?</summary>
        <p>Suporte por chat e e-mail (oi@aulado.com.br) em todos os planos. Plano Profissional e Escala têm suporte prioritário.</p>
      </details>
    </div>
  </div>
</section>

<!-- FORMULÁRIO -->
<section class="contact" id="contato">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-copy">
        <h2>Comece seu teste grátis hoje</h2>
        <p>14 dias sem cartão, sem compromisso. Acesso ao sistema completo com dados de exemplo para explorar.</p>
        <ul class="contact-bullets">
          <li>✓ Configuração em menos de 15 minutos</li>
          <li>✓ Migração dos seus dados incluída</li>
          <li>✓ Suporte humano durante todo o trial</li>
        </ul>
      </div>
      <form
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        class="contact-form"
        id="contact-form"
      >
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="_subject" value="Novo lead — Aulado" />

        <div class="form-group">
          <label for="name">Nome completo</label>
          <input type="text" id="name" name="name" placeholder="Seu nome" required />
        </div>
        <div class="form-group">
          <label for="business">Nome do seu negócio</label>
          <input type="text" id="business" name="business" placeholder="Ex: Creche do Thor" required />
        </div>
        <div class="form-group">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" placeholder="seu@email.com.br" required />
        </div>
        <div class="form-group">
          <label for="segment">Tipo de negócio</label>
          <select id="segment" name="segment" required>
            <option value="">Selecione...</option>
            <option value="creche">Creche de cachorro</option>
            <option value="hotel">Hotel pet</option>
            <option value="banho-tosa">Banho e tosa</option>
            <option value="todos">Creche + hotel + banho e tosa</option>
          </select>
        </div>
        <div class="form-group">
          <label for="coupon">Cupom (opcional)</label>
          <input type="text" id="coupon" name="coupon" placeholder="Ex: FUNDADOR" />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Quero meu acesso grátis →</button>
        <div class="form-success" id="form-success" aria-live="polite" hidden>
          ✅ Recebido! Seu acesso chega por e-mail em até 1 dia útil.
        </div>
      </form>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo logo-light">
          <svg width="28" height="28" viewBox="0 0 36 36" fill="none">
            <rect width="36" height="36" rx="8" fill="#D98232"/>
            <path d="M12 22c0-1.5.8-2.8 2-3.5-.3-.5-.5-1-.5-1.5 0-1.7 1.3-3 3-3s3 1.3 3 3c0 .5-.2 1-.5 1.5 1.2.7 2 2 2 3.5H12z" fill="white"/>
            <circle cx="13" cy="13" r="1.5" fill="white"/>
            <circle cx="23" cy="13" r="1.5" fill="white"/>
            <circle cx="10" cy="17" r="1.5" fill="white"/>
            <circle cx="26" cy="17" r="1.5" fill="white"/>
          </svg>
          <span>Aulado</span>
        </a>
        <p>Sistema de gestão para pet negócios.<br/>Feito para quem cuida com cuidado.</p>
      </div>
      <div class="footer-links">
        <div>
          <strong>Produto</strong>
          <a href="#funcionalidades">Funcionalidades</a>
          <a href="#planos">Planos</a>
          <a href="/blog">Blog</a>
        </div>
        <div>
          <strong>Empresa</strong>
          <a href="mailto:oi@aulado.com.br">oi@aulado.com.br</a>
          <a href="/politica-de-privacidade">Privacidade</a>
          <a href="/termos-de-uso">Termos de uso</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Aulado. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const nav = document.querySelector('nav');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('nav-open');
  });

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
    if (res.ok) { form.reset(); if (success) success.hidden = false; }
  });
</script>

<style>
  .site-header { background: var(--brown); padding: 1rem 0; position: sticky; top: 0; z-index: 100; }
  .site-header .container { display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: #fff; font-family: var(--font-title); font-weight: 700; font-size: 1.2rem; }
  nav { display: flex; align-items: center; gap: 1.5rem; }
  nav a { color: #fff; text-decoration: none; font-size: 0.95rem; }
  nav a:hover { color: var(--caramel); }
  .menu-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
  .menu-toggle span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 2px; }

  .hero { background: var(--brown); color: #fff; padding: 5rem 0 4rem; }
  .hero .container { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .hero-badge { display: inline-block; background: var(--caramel); color: #fff; padding: 0.4rem 1rem; border-radius: 99px; font-size: 0.85rem; font-weight: 600; margin-bottom: 1.25rem; }
  .hero h1 { font-size: clamp(2rem, 4vw, 3rem); color: #fff; margin-bottom: 1.25rem; }
  .hero p { font-size: 1.1rem; color: #ccc; margin-bottom: 2rem; max-width: 520px; }
  .hero-actions { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .hero-note { font-size: 0.85rem; color: #aaa; }

  .hero-card { background: #fff; color: var(--brown); border-radius: 14px; padding: 1.75rem; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
  .hcard-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; font-size: 0.85rem; color: #666; }
  .hcard-dot { width: 10px; height: 10px; border-radius: 50%; }
  .hcard-dot.green { background: var(--green); }
  .hcard-stat { font-family: var(--font-title); font-size: 3rem; font-weight: 800; line-height: 1; }
  .hcard-stat span { font-size: 1.5rem; color: #999; }
  .hcard-label { font-size: 0.85rem; color: #666; margin-bottom: 1.25rem; }
  .hcard-checks { display: flex; flex-direction: column; gap: 0.5rem; }
  .hcheck { font-size: 0.85rem; padding: 0.4rem 0.75rem; border-radius: 6px; }
  .hcheck.done { background: #edfaf3; color: var(--green); }
  .hcheck.pending { background: var(--sand); color: #888; }

  .pain { background: var(--sand); padding: 4rem 0; text-align: center; }
  .pain h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto; }
  .pain-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; margin-bottom: 2rem; }
  .pain-item { background: #fff; border-radius: 12px; padding: 1.5rem; text-align: left; }
  .pain-icon { font-size: 1.75rem; display: block; margin-bottom: 0.75rem; }
  .pain-item p { font-size: 0.95rem; color: #555; }
  .pain-cta { font-family: var(--font-title); font-size: 1.15rem; font-weight: 700; color: var(--caramel); }

  .features { padding: 5rem 0; }
  .features h2, .pricing h2, .faq h2 { text-align: center; font-size: clamp(1.5rem, 3vw, 2.2rem); margin-bottom: 0.75rem; }
  .section-subtitle { text-align: center; color: #666; margin-bottom: 3rem; }
  .features-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
  .feature-card { background: var(--sand); border-radius: 14px; padding: 1.75rem; }
  .feature-icon { font-size: 2rem; margin-bottom: 1rem; }
  .feature-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .feature-card p { font-size: 0.95rem; color: #555; }

  .proof { background: var(--caramel); padding: 3rem 0; }
  .proof-stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; text-align: center; }
  .stat-number { display: block; font-family: var(--font-title); font-size: 2.5rem; font-weight: 800; color: #fff; }
  .stat-label { display: block; font-size: 0.9rem; color: rgba(255,255,255,0.85); margin-top: 0.25rem; }

  .pricing { background: var(--sand); padding: 5rem 0; }
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin: 2.5rem 0; }
  .plan-card { background: #fff; border-radius: 14px; padding: 2rem; position: relative; }
  .plan-card.plan-featured { border: 2px solid var(--caramel); }
  .plan-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--caramel); color: #fff; font-size: 0.78rem; font-weight: 700; padding: 0.2rem 0.9rem; border-radius: 99px; white-space: nowrap; }
  .plan-name { font-family: var(--font-title); font-weight: 700; font-size: 1.1rem; margin-bottom: 0.75rem; color: var(--caramel); }
