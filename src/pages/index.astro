---
import Layout from '../layouts/Layout.astro';

const siteSchema = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Aupipet",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": [
      { "@type": "Offer", "name": "Essencial", "price": "197", "priceCurrency": "BRL", "billingIncrement": "P1M" },
      { "@type": "Offer", "name": "Profissional", "price": "397", "priceCurrency": "BRL", "billingIncrement": "P1M" },
      { "@type": "Offer", "name": "Escala", "price": "697", "priceCurrency": "BRL", "billingIncrement": "P1M" }
    ],
    "url": "https://aupipet.com.br",
    "description": "Sistema de gestão white label para creches de cachorro, hotéis pet e banho e tosa."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Preciso de cartão de crédito para o teste grátis?",
        "acceptedAnswer": { "@type": "Answer", "text": "Não. O trial de 14 dias é totalmente gratuito, sem cartão e sem compromisso." }
      },
      {
        "@type": "Question",
        "name": "O que é o plano white label?",
        "acceptedAnswer": { "@type": "Answer", "text": "No plano Profissional e Escala, o sistema aparece com o nome e a identidade visual do seu negócio — para os seus tutores, é o seu próprio app." }
      },
      {
        "@type": "Question",
        "name": "Posso migrar meus dados do sistema atual?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sim, e sem falar com ninguém. A importação é automática: você envia planilhas (Excel/CSV), PDFs ou fotos das suas fichas e a inteligência da Aupipet lê, organiza e cadastra tutores, pets e pacotes sozinha." }
      },
      {
        "@type": "Question",
        "name": "Funciona para banho e tosa também?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sim — agendamento, lembretes, pacotes e cobranças funcionam para creche, hotel pet e banho e tosa." }
      },
      {
        "@type": "Question",
        "name": "Preciso falar com alguém para usar a Aupipet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Não. A Aupipet é 100% self-service: você cria a conta, importa seus dados e configura tudo sozinho. Tutoriais no app, central de ajuda e um assistente automático respondem suas dúvidas na hora, 24 horas por dia." }
      }
    ]
  }
];

const FORMSPREE_ID = import.meta.env.FORMSPREE_ID || 'xyzabcde';
---

<Layout
  title="Aupipet — Sistema de gestão para creche, hotel pet e banho e tosa"
  description="Aupipet é o sistema que organiza agenda, tutores, cobranças e relatórios do seu pet negócio — com a sua marca. Trial de 14 dias sem cartão."
  schema={siteSchema}
>

<!-- HEADER -->
<header class="site-header">
  <div class="container">
    <a href="/" class="logo" aria-label="Aupipet — início">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
        <rect width="36" height="36" rx="8" fill="#D98232"/>
        <g fill="#fff">
          <ellipse cx="9.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(-22 9.5 17.5)"/>
          <ellipse cx="14.8" cy="11.6" rx="2.7" ry="3.9" transform="rotate(-8 14.8 11.6)"/>
          <ellipse cx="21.2" cy="11.6" rx="2.7" ry="3.9" transform="rotate(8 21.2 11.6)"/>
          <ellipse cx="26.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(22 26.5 17.5)"/>
          <path d="M18 18.6C23.1 18.6 27 21.9 27 25.9C27 29.3 24.2 30.9 21.4 32.3C20 33 19.1 33.5 18 33.5C16.9 33.5 16 33 14.6 32.3C11.8 30.9 9 29.3 9 25.9C9 21.9 12.9 18.6 18 18.6Z"/>
        </g>
      </svg>
      <span>Aupipet</span>
    </a>
    <nav>
      <a href="#funcionalidades">Funcionalidades</a>
      <a href="#planos">Planos</a>
      <a href="/blog">Blog</a>
      <a href="https://app.aupipet.com.br/comecar" class="btn btn-primary nav-cta">Teste grátis</a>
    </nav>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">🐾 Cupom FUNDADOR — R$97/mês vitalício · apenas 10 vagas</div>
      <h1>Seu pet negócio organizado.<br/>Sua marca em cada detalhe.</h1>
      <h2 class="hero-sub">Sistema de gestão para creche de cachorro, hotel pet e banho e tosa</h2>
      <p>Aupipet é o sistema que cuida da agenda, dos tutores, das cobranças e dos relatórios da sua creche, hotel pet ou banho e tosa — com a cara do seu negócio, sem complicação.</p>
      <div class="hero-actions">
        <a href="https://app.aupipet.com.br/comecar" class="btn btn-primary">Começar teste grátis de 14 dias</a>
        <span class="hero-note">Sem cartão · Sem compromisso · Acesso imediato</span>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card">
        <div class="hcard-header">
          <span class="hcard-dot green"></span>
          <span class="hcard-title">Hoje — ocupação</span>
        </div>
        <div class="hcard-stat">28<span>/30</span></div>
        <div class="hcard-label">cães presentes</div>
        <div class="hcard-checks">
          <div class="hcheck done">✓ Thor — check-in 08:12</div>
          <div class="hcheck done">✓ Mel — check-in 08:45</div>
          <div class="hcheck pending">⏳ Bob — previsto 09:30</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROBLEMA -->
<section class="pain">
  <div class="container">
    <h2>Você ainda gerencia no caderno, no WhatsApp e na memória?</h2>
    <div class="pain-grid">
      <div class="pain-item">
        <span class="pain-icon">📋</span>
        <p>Ficha de cada cão espalhada em papel, planilha e cabeça de funcionário</p>
      </div>
      <div class="pain-item">
        <span class="pain-icon">💸</span>
        <p>Cobrança manual que constrange — e inadimplência que sangra o caixa</p>
      </div>
      <div class="pain-item">
        <span class="pain-icon">📅</span>
        <p>Agendamento por WhatsApp que some, esquece e gera confusão</p>
      </div>
      <div class="pain-item">
        <span class="pain-icon">📊</span>
        <p>Sem saber quanto faturou, quantos faltaram ou quem sumiu há semanas</p>
      </div>
    </div>
    <p class="pain-cta">Isso não é falta de esforço — é falta de sistema. A Aupipet resolve.</p>
  </div>
</section>

<!-- FUNCIONALIDADES -->
<section class="features" id="funcionalidades">
  <div class="container">
    <h2>Tudo que você precisa em um lugar só</h2>
    <p class="section-subtitle">Desenvolvido com quem já opera pet negócio de verdade — sem funcionalidade de enfeite.</p>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">📅</div>
        <h3>Agenda inteligente</h3>
        <p>Controle de vagas por porte, bloqueio automático na capacidade máxima, lista de espera e confirmação automática na véspera.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🐾</div>
        <h3>Ficha digital completa</h3>
        <p>Saúde, vacinação, comportamento, rotina e autorizações do tutor — acessíveis para toda a equipe, atualizadas em tempo real.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">💳</div>
        <h3>Cobrança recorrente</h3>
        <p>Mensalistas e pacotes com cobrança automática, régua de inadimplência e extrato de saldo para o tutor. Você para de cobrar.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📦</div>
        <h3>Pacotes de diárias</h3>
        <p>Venda, controle de saldo e aviso automático de vencimento. O sistema debita, avisa o tutor e gera a recompra.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <h3>Relatórios em tempo real</h3>
        <p>Ocupação, faturamento por serviço, ticket médio, inativos, faltas e previsão de caixa — prontos, sem montar planilha.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎨</div>
        <h3>White label completo</h3>
        <p>Logo, cor e nome do seu negócio em todo o painel, nas páginas do tutor e nos e-mails. Para seus clientes, é o seu app.</p>
      </div>
    </div>
  </div>
</section>

<!-- IMPORTAÇÃO AUTOMÁTICA -->
<section class="import" id="importacao">
  <div class="container">
    <div class="import-inner">
      <div class="import-copy">
        <span class="import-tag">🤖 Migração sem dor de cabeça</span>
        <h2>Traga seus dados de qualquer lugar — a Aupipet entende sozinha</h2>
        <p>Está num sistema antigo, numa planilha bagunçada ou só em fichas de papel? Sem problema e sem precisar falar com ninguém. Envie seus arquivos e a inteligência da Aupipet lê, organiza e cadastra tudo automaticamente: tutores, pets, vacinas, pacotes e saldos.</p>
        <ul class="import-steps">
          <li><span>1</span> Você arrasta os arquivos (Excel/CSV, PDF ou fotos das fichas)</li>
          <li><span>2</span> A IA interpreta e organiza os dados, mesmo desestruturados</li>
          <li><span>3</span> Você revisa um resumo e confirma com um clique</li>
          <li><span>4</span> Tudo entra cadastrado no sistema, pronto para usar</li>
        </ul>
        <a href="https://app.aupipet.com.br/comecar" class="btn btn-primary">Importar meus dados agora</a>
      </div>
      <div class="import-visual">
        <div class="import-card">
          <div class="import-files">
            <span class="ifile">📄 fichas.pdf</span>
            <span class="ifile">📊 clientes.xlsx</span>
            <span class="ifile">📷 ficha_thor.jpg</span>
          </div>
          <div class="import-arrow">↓ IA lendo e organizando…</div>
          <div class="import-result">
            <div class="ires-row"><strong>148</strong> tutores</div>
            <div class="ires-row"><strong>173</strong> pets</div>
            <div class="ires-row"><strong>96</strong> pacotes ativos</div>
            <div class="ires-ok">✓ Pronto para confirmar</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF -->
<section class="proof">
  <div class="container">
    <div class="proof-stat-grid">
      <div class="proof-stat">
        <span class="stat-number">-68%</span>
        <span class="stat-label">nas faltas com confirmação automática</span>
      </div>
      <div class="proof-stat">
        <span class="stat-number">14 dias</span>
        <span class="stat-label">para organizar o que estava no caderno</span>
      </div>
      <div class="proof-stat">
        <span class="stat-number">100%</span>
        <span class="stat-label">da sua marca nos e-mails e painel do tutor</span>
      </div>
    </div>
  </div>
</section>

<!-- PLANOS -->
<section class="pricing" id="planos">
  <div class="container">
    <h2>Planos que crescem com você</h2>
    <p class="section-subtitle">Todos com trial de 14 dias gratuito. Planos anuais com 2 meses grátis.</p>
    <div class="pricing-grid">
      <div class="plan-card">
        <div class="plan-name">Essencial</div>
        <div class="plan-price">R$&nbsp;197<span>/mês</span></div>
        <div class="plan-annual">ou R$1.970/ano (2 meses grátis)</div>
        <ul class="plan-features">
          <li>✓ 1 unidade · 2 usuários</li>
          <li>✓ Agenda e check-in/out</li>
          <li>✓ Ficha digital dos pets</li>
          <li>✓ Controle de pacotes</li>
          <li>✓ Relatórios básicos</li>
          <li>✓ Cobrança recorrente</li>
        </ul>
        <a href="https://app.aupipet.com.br/comecar" class="btn btn-outline" style="width:100%;text-align:center;">Começar grátis</a>
      </div>

      <div class="plan-card plan-featured">
        <div class="plan-badge">Mais popular</div>
        <div class="plan-name">Profissional</div>
        <div class="plan-price">R$&nbsp;397<span>/mês</span></div>
        <div class="plan-annual">ou R$3.970/ano (2 meses grátis)</div>
        <ul class="plan-features">
          <li>✓ Tudo do Essencial</li>
          <li>✓ White label completo</li>
          <li>✓ Usuários ilimitados</li>
          <li>✓ Relatórios avançados</li>
          <li>✓ Subdomínio próprio</li>
          <li>✓ Importação automática com IA</li>
        </ul>
        <a href="https://app.aupipet.com.br/comecar" class="btn btn-primary" style="width:100%;text-align:center;">Começar grátis</a>
      </div>

      <div class="plan-card">
        <div class="plan-name">Escala</div>
        <div class="plan-price">R$&nbsp;697<span>/mês</span></div>
        <div class="plan-annual">ou R$6.970/ano (2 meses grátis)</div>
        <ul class="plan-features">
          <li>✓ Tudo do Profissional</li>
          <li>✓ Múltiplas unidades</li>
          <li>✓ Painel consolidado</li>
          <li>✓ API e integrações</li>
          <li>✓ Importação automática ilimitada</li>
          <li>✓ SLA de disponibilidade</li>
        </ul>
        <a href="https://app.aupipet.com.br/comecar" class="btn btn-outline" style="width:100%;text-align:center;">Começar grátis</a>
      </div>
    </div>

    <div class="coupon-box">
      <strong>🏷️ Cupom FUNDADOR</strong> — R$97/mês vitalício para os primeiros 10 clientes. Informe no formulário abaixo.
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq" id="faq">
  <div class="container">
    <h2>Perguntas frequentes</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Preciso de cartão de crédito para o teste?</summary>
        <p>Não. O trial de 14 dias é totalmente gratuito, sem cartão e sem compromisso. Você só paga se decidir continuar.</p>
      </details>
      <details class="faq-item">
        <summary>O que é o plano white label?</summary>
        <p>No plano Profissional e Escala, o sistema aparece com o nome e a identidade visual do seu negócio — logo, cores e domínio. Para os seus tutores, é o seu próprio app.</p>
      </details>
      <details class="faq-item">
        <summary>Posso migrar meus dados do sistema atual?</summary>
        <p>Sim, e sem falar com ninguém. A importação é automática: você envia planilhas (Excel/CSV), PDFs ou até fotos das suas fichas de papel, e a inteligência da Aupipet lê, organiza e cadastra tutores, pets e pacotes sozinha. Você só confere e confirma.</p>
      </details>
      <details class="faq-item">
        <summary>Funciona para banho e tosa também?</summary>
        <p>Sim — agendamento, lembretes automáticos, pacotes e cobranças funcionam para creche, hotel pet e banho e tosa.</p>
      </details>
      <details class="faq-item">
        <summary>Tem aplicativo para o tutor?</summary>
        <p>Sim. O tutor acessa a agenda, o histórico do pet e os comprovantes pelo app web responsivo — com a cara do seu negócio.</p>
      </details>
      <details class="faq-item">
        <summary>Preciso falar com alguém ou agendar uma demonstração?</summary>
        <p>Não. A Aupipet é 100% self-service: você cria a conta, importa seus dados e começa a usar na hora — sem reunião, sem vendedor, sem espera. Tudo o que você precisa está dentro do app.</p>
      </details>
      <details class="faq-item">
        <summary>E se eu tiver dúvidas no caminho?</summary>
        <p>Você resolve sozinho, na hora: tutoriais guiados dentro do sistema, central de ajuda com busca e um assistente automático disponível 24/7. Sem ticket, sem fila, sem horário comercial.</p>
      </details>
    </div>
  </div>
</section>

<!-- FORMULÁRIO -->
<section class="contact" id="contato">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-copy">
        <h2>Comece seu teste grátis hoje</h2>
        <p>14 dias sem cartão, sem compromisso e sem precisar falar com ninguém. Crie a conta e o acesso é liberado na hora.</p>
        <ul class="contact-bullets">
          <li>✓ Configuração em menos de 15 minutos, sozinho</li>
          <li>✓ Importação automática dos seus dados (Excel, PDF ou foto)</li>
          <li>✓ Ajuda automática 24/7 dentro do app</li>
        </ul>
      </div>
      <form
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        class="contact-form"
        id="contact-form"
      >
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="_subject" value="Novo lead — Aupipet" />

        <div class="form-group">
          <label for="name">Nome completo</label>
          <input type="text" id="name" name="name" placeholder="Seu nome" required />
        </div>
        <div class="form-group">
          <label for="business">Nome do seu negócio</label>
          <input type="text" id="business" name="business" placeholder="Ex: Creche do Thor" required />
        </div>
        <div class="form-group">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" placeholder="seu@email.com.br" required />
        </div>
        <div class="form-group">
          <label for="segment">Tipo de negócio</label>
          <select id="segment" name="segment" required>
            <option value="">Selecione...</option>
            <option value="creche">Creche de cachorro</option>
            <option value="hotel">Hotel pet</option>
            <option value="banho-tosa">Banho e tosa</option>
            <option value="todos">Creche + hotel + banho e tosa</option>
          </select>
        </div>
        <div class="form-group">
          <label for="coupon">Cupom (opcional)</label>
          <input type="text" id="coupon" name="coupon" placeholder="Ex: FUNDADOR" />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">Quero meu acesso grátis →</button>
        <p style="font-size:.8rem;opacity:.7;margin-top:.5rem;text-align:center">Você vai criar sua conta na próxima tela. Leva 1 minuto.</p>
      </form>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo logo-light">
          <svg width="28" height="28" viewBox="0 0 36 36" fill="none">
            <rect width="36" height="36" rx="8" fill="#D98232"/>
            <g fill="#fff">
              <ellipse cx="9.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(-22 9.5 17.5)"/>
              <ellipse cx="14.8" cy="11.6" rx="2.7" ry="3.9" transform="rotate(-8 14.8 11.6)"/>
              <ellipse cx="21.2" cy="11.6" rx="2.7" ry="3.9" transform="rotate(8 21.2 11.6)"/>
              <ellipse cx="26.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(22 26.5 17.5)"/>
              <path d="M18 18.6C23.1 18.6 27 21.9 27 25.9C27 29.3 24.2 30.9 21.4 32.3C20 33 19.1 33.5 18 33.5C16.9 33.5 16 33 14.6 32.3C11.8 30.9 9 29.3 9 25.9C9 21.9 12.9 18.6 18 18.6Z"/>
            </g>
          </svg>
          <span>Aupipet</span>
        </a>
        <p>Sistema de gestão para pet negócios.<br/>Feito para quem cuida com cuidado.</p>
      </div>
      <div class="footer-links">
        <div>
          <strong>Produto</strong>
          <a href="/creche-de-cachorro">Sistema para creche</a>
          <a href="/hotel-pet">Sistema para hotel pet</a>
          <a href="/banho-e-tosa">Software banho e tosa</a>
          <a href="/melhor-sistema-para-creche-de-cachorro">Melhor sistema p/ creche</a>
          <a href="/quanto-custa-um-sistema-de-gestao-para-pet">Quanto custa</a>
          <a href="#planos">Planos</a>
          <a href="/blog">Blog</a>
        </div>
        <div>
          <strong>Ajuda</strong>
          <a href="#faq">Central de ajuda</a>
          <a href="/politica-de-privacidade">Privacidade</a>
          <a href="/termos-de-uso">Termos de uso</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Aupipet. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const nav = document.querySelector('nav');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('nav-open');
  });

  // Self-service: o formulário leva direto ao cadastro do app (sem lead/Formspree).
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const params = new URLSearchParams();
    const seg = String(data.get('segment') || '');
    const cupom = String(data.get('coupon') || '');
    if (seg) params.set('segmento', seg);
    if (cupom) params.set('cupom', cupom);
    const qs = params.toString();
    window.location.href = 'https://app.aupipet.com.br/comecar' + (qs ? '?' + qs : '');
  });
</script>

<style>
  .site-header { background: var(--brown); padding: 1rem 0; position: sticky; top: 0; z-index: 100; }
  .site-header .container { display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: #fff; font-family: var(--font-title); font-weight: 700; font-size: 1.2rem; }
  nav { display: flex; align-items: center; gap: 1.5rem; }
  nav a { color: #fff; text-decoration: none; font-size: 0.95rem; }
