---
// Cabeçalho compartilhado das landing pages de SEO.
---
<header class="site-header">
  <div class="container">
    <a href="/" class="logo" aria-label="Aupi — início">
      <svg width="34" height="34" viewBox="0 0 36 36" fill="none">
        <rect width="36" height="36" rx="8" fill="#D98232"/>
        <g fill="#fff">
          <ellipse cx="9.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(-22 9.5 17.5)"/>
          <ellipse cx="14.8" cy="11.6" rx="2.7" ry="3.9" transform="rotate(-8 14.8 11.6)"/>
          <ellipse cx="21.2" cy="11.6" rx="2.7" ry="3.9" transform="rotate(8 21.2 11.6)"/>
          <ellipse cx="26.5" cy="17.5" rx="2.5" ry="3.4" transform="rotate(22 26.5 17.5)"/>
          <path d="M18 18.6C23.1 18.6 27 21.9 27 25.9C27 29.3 24.2 30.9 21.4 32.3C20 33 19.1 33.5 18 33.5C16.9 33.5 16 33 14.6 32.3C11.8 30.9 9 29.3 9 25.9C9 21.9 12.9 18.6 18 18.6Z"/>
        </g>
      </svg>
      <span>Aupi</span>
    </a>
    <nav>
      <a href="/creche-de-cachorro">Creche</a>
      <a href="/hotel-pet">Hotel pet</a>
      <a href="/banho-e-tosa">Banho e tosa</a>
      <a href="/#planos">Planos</a>
      <a href="/blog">Blog</a>
      <a href="https://app.aupipet.com.br/comecar" class="btn btn-primary nav-cta">Teste grátis</a>
    </nav>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header { background: var(--brown); padding: 1rem 0; position: sticky; top: 0; z-index: 100; }
  .site-header .container { display: flex; align-items: center; justify-content: space-between; }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: #fff; font-family: var(--font-title); font-weight: 700; font-size: 1.2rem; }
  nav { display: flex; align-items: center; gap: 1.25rem; }
  nav a { color: #fff; text-decoration: none; font-size: 0.95rem; }
  nav a:hover { color: var(--caramel); }
  .menu-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
  .menu-toggle span { display: block; width: 22px; height: 2px; background: #fff; border-radius: 2px; }
  @media (max-width: 860px) {
    nav a:not(.nav-cta) { display: none; }
    .menu-toggle { display: flex; }
  }
</style>
